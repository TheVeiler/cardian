{
	"compilerOptions": {
		"allowSyntheticDefaultImports": true,
		"noImplicitAny": true,
		"module": "esnext",
		"target": "es2022",
		"moduleResolution": "node",
		"allowJs": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"baseUrl": ".",
		"outDir": "dist",
		"types": ["node", "webpack/module"],

		"paths": {
			"/common": ["src/common/index"],
            "/common/*": ["src/common/*"],
			"/blackjack": ["src/blackjack/index"],
            "/blackjack/*": ["src/blackjack/*"],
			"/decklists": ["src/decklists/index"],
            "/decklists/*": ["src/decklists/*"],
            "/Cardian": ["src/Cardian"]
		}
	},
	"files": ["src/Cardian.ts"]
}

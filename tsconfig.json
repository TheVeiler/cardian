{
	"compilerOptions": {
		"allowSyntheticDefaultImports": true,
		"noImplicitAny": true,
		"module": "esnext",
		"target": "es2022",
		"moduleResolution": "node",
		"allowJs": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"baseUrl": ".",
		"outDir": "dist",
		"types": ["node", "webpack/module"],

		"paths": {
			"/common": ["src/common/index"],
			"/blackjack": ["src/blackjack/index"],
			"/decklists": ["src/decklists/index"]
		}
	},
	"files": ["src/Cardian.ts"]
}

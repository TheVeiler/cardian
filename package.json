{
	"name": "cardian",
	"version": "2.0.1",
	"description": "Cardian is a utility library whose purpose is to make creating apps using cards easier.",
	"author": "TheVeiler",
	"license": "ISC",
	"keywords": [],
	"homepage": "https://github.com/TheVeiler/Cardian#readme",
	"bugs": {
		"url": "https://github.com/TheVeiler/Cardian/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/TheVeiler/Cardian.git"
	},
	"type": "module",
	"main": "dist/Cardian.js",
	"types": "dist/Cardian.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"prebuild": "npm run format && npm run lint",
		"build": "webpack --mode=production --config-node-env=production",
		"build:dev": "webpack --mode=development",
		"build:watch": "webpack --watch",
		"format": "prettier . --write",
		"lint": "eslint",
		"prestart": "npm run build",
		"start": "node ./dist/index.js",
		"prepack": "npm run build",
		"pack": "npm pack --pack-destination .",
		"postpack": "npm run clean",
		"predeploy": "npm run build",
		"deploy": "gh-pages -d dist",
		"postdeploy": "npm run clean",
		"clean": "rm -r ./dist"
	},
	"devDependencies": {
		"@eslint/css": "^0.9.0",
		"@eslint/js": "^9.30.1",
		"@eslint/json": "^0.14.0",
		"@eslint/markdown": "^6.6.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.5.0",
		"copy-webpack-plugin": "^14.0.0",
		"eslint": "^9.30.1",
		"globals": "^16.3.0",
		"jest": "^30.0.4",
		"prettier": "^3.6.2",
		"ts-jest": "^29.4.0",
		"ts-loader": "^9.5.4",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.35.1",
		"webpack": "^5.105.4",
		"webpack-cli": "^7.0.2"
	}
}

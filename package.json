{
	"name": "cardian",
	"version": "1.3.1",
	"description": "Cardian is an utility library to help you making apps using cards.",
	"author": "TheVeiler",
	"license": "ISC",
	"keywords": [],
	"homepage": "https://github.com/TheVeiler/Cardian#readme",
	"bugs": {
		"url": "https://github.com/TheVeiler/Cardian/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/TheVeiler/Cardian.git"
	},
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist/*",
		"public/*"
	],
	"scripts": {
		"dev": "tsx watch ./src/plugins/games/blackjack/index.ts",
		"format": "prettier . --write",
		"lint": "eslint",
        "prebuild": "npm run format && npm run lint",
		"build": "tsc && tsc-alias --resolve-full-paths",
		"build:watch": "concurrently --kill-others \"tsc -w\" \"tsc-alias --resolve-full-paths -w\"",
		"prestart": "npm run build",
		"start": "node ./dist/index.js",
		"prepack": "npm run build",
		"pack": "npm pack --pack-destination ."
	},
	"devDependencies": {
		"@eslint/css": "^0.9.0",
		"@eslint/js": "^9.30.1",
		"@eslint/json": "^0.14.0",
		"@eslint/markdown": "^6.6.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^24.0.10",
		"concurrently": "^9.2.1",
		"eslint": "^9.30.1",
		"globals": "^16.3.0",
		"jest": "^30.0.4",
		"prettier": "^3.6.2",
		"ts-jest": "^29.4.0",
		"tsc-alias": "^1.8.16",
		"tsx": "^4.20.3",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.35.1"
	}
}
